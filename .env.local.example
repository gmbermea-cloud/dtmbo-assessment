# Read-only access to the Items sheet (server-side only — used by /api/items)
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# The spreadsheet ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Postgres connection string. When you link a database in the Vercel dashboard
# (Storage tab), this is filled in automatically — for local dev, run
# `npx vercel env pull` after linking instead of setting it by hand.
DATABASE_URL=your_postgres_connection_string_here
