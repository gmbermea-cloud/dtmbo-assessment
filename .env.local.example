# The spreadsheet ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Service account credentials — used to both read the Items tab and write to
# the Responses tab. Paste the full service account JSON as a single-line
# string, or base64-encode it. The sheet must be shared with the service
# account's client_email as an Editor.
GOOGLE_SERVICE_ACCOUNT_KEY=your_service_account_json_or_base64_here
